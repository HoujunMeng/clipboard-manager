<Window x:Class="ClipboardManager.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置"
        Width="360"
        Height="220"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow"
        ShowInTaskbar="False">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- 标题 -->
            <RowDefinition Height="Auto" />  <!-- 分隔 -->
            <RowDefinition Height="*" />     <!-- 内容 -->
            <RowDefinition Height="Auto" />  <!-- 分隔 -->
            <RowDefinition Height="Auto" />  <!-- 按钮 -->
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0"
                   Text="设置"
                   FontSize="14"
                   FontWeight="SemiBold"
                   Foreground="#FF1A1A1A"
                   Margin="0,0,0,16" />

        <Separator Grid.Row="1" />

        <!-- 内容 -->
        <StackPanel Grid.Row="2"
                    Margin="0,16,0,0">

            <!-- 保留天数 -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="保留天数："
                           FontSize="13"
                           Foreground="#FF1A1A1A"
                           VerticalAlignment="Center" />

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <RadioButton x:Name="Day1"
                                 Content="1 天"
                                 GroupName="Retention"
                                 FontSize="13"
                                 Margin="0,0,8,0" />
                    <RadioButton x:Name="Day3"
                                 Content="3 天"
                                 GroupName="Retention"
                                 FontSize="13"
                                 Margin="0,0,8,0" />
                    <RadioButton x:Name="Day5"
                                 Content="5 天"
                                 GroupName="Retention"
                                 FontSize="13" />
                </StackPanel>
            </Grid>

            <!-- 开机启动 -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="开机自动启动"
                           FontSize="13"
                           Foreground="#FF1A1A1A"
                           VerticalAlignment="Center" />

                <ToggleButton x:Name="LaunchToggle"
                              Grid.Column="1"
                              HorizontalAlignment="Right"
                              Width="44"
                              Height="24"
                              IsChecked="True"
                              Style="{StaticResource SwitchToggle}" />
            </Grid>
        </StackPanel>

        <Separator Grid.Row="3" />

        <!-- 按钮 -->
        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="取消"
                    Width="70"
                    Height="28"
                    IsCancel="True"
                    Click="OnCancel"
                    Style="{StaticResource TextButton}" />
            <Button Content="保存"
                    Width="70"
                    Height="28"
                    Margin="8,0,0,0"
                    IsDefault="True"
                    Click="OnSave"
                    Style="{StaticResource PrimaryButton}" />
        </StackPanel>
    </Grid>
</Window>
