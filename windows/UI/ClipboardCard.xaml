<UserControl x:Class="ClipboardManager.UI.ClipboardCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ClipboardManager.Converters"
             Cursor="Hand">

    <UserControl.Resources>
        <conv:InverseBoolConverter x:Key="InverseBool" />
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Border x:Name="CardRoot"
            Background="White"
            BorderBrush="#FFE0E0E0"
            BorderThickness="1"
            CornerRadius="6"
            ClipToBounds="True">

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- 置顶蓝色标识条（左边缘） -->
            <Border x:Name="PinBar"
                    Grid.Column="0"
                    Width="3"
                    Background="#FF4A90D9"
                    CornerRadius="1,0,0,1"
                    Visibility="Collapsed"
                    Margin="0,-8,0,-8" />

            <!-- 主内容区 -->
            <Grid Grid.Column="1"
                  Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />      <!-- 预览区 -->
                    <RowDefinition Height="Auto" />   <!-- 底栏 -->
                </Grid.RowDefinitions>

                <!-- ═══ 预览区 ═══ -->
                <Grid Grid.Row="0"
                      x:Name="PreviewArea">
                    <!-- 文字预览 -->
                    <TextBlock x:Name="TextPreview"
                               FontSize="13"
                               Foreground="#FF1A1A1A"
                               TextWrapping="Wrap"
                               MaxHeight="160"
                               LineHeight="18"
                               TextTrimming="CharacterEllipsis"
                               Visibility="Collapsed" />

                    <!-- 图片预览 -->
                    <Image x:Name="ImagePreview"
                           Stretch="Uniform"
                           MaxWidth="330"
                           MaxHeight="140"
                           MinHeight="36"
                           Visibility="Collapsed"
                           RenderOptions.BitmapScalingMode="Fant" />

                    <!-- 图片已丢失 -->
                    <TextBlock x:Name="ImageLostText"
                               FontSize="13"
                               Foreground="#FF333333"
                               Text="[图片已丢失]"
                               Visibility="Collapsed" />
                </Grid>

                <!-- ═══ 底栏 ═══ -->
                <Grid Grid.Row="1"
                      Height="20"
                      Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- 相对时间 -->
                    <TextBlock Grid.Column="0"
                               x:Name="TimeLabel"
                               FontSize="12"
                               Foreground="#FF333333"
                               VerticalAlignment="Center" />

                    <!-- 间隔 -->
                    <TextBlock Grid.Column="1" />

                    <!-- 置顶按钮 -->
                    <Button Grid.Column="2"
                            x:Name="PinButton"
                            Width="20"
                            Height="20"
                            Click="OnPinClick"
                            Style="{StaticResource IconButton}"
                            ToolTip="置顶">
                        <TextBlock x:Name="PinIcon"
                                   FontSize="12"
                                   Foreground="#FF888888"
                                   Text="📌" />
                    </Button>

                    <!-- 删除按钮 -->
                    <Button Grid.Column="3"
                            Width="20"
                            Height="20"
                            Margin="8,0,0,0"
                            Click="OnDeleteClick"
                            Style="{StaticResource IconButton}"
                            ToolTip="删除">
                        <TextBlock x:Name="DeleteIcon"
                                   FontSize="12"
                                   Foreground="#FF555555"
                                   Text="✕" />
                    </Button>
                </Grid>
            </Grid>
        </Grid>
    </Border>

    <!-- Triggers 用于数据和交互状态更新 -->
    <UserControl.Triggers>
        <!-- 置顶状态 → 蓝色标识条可见 -->
        <DataTrigger Binding="{Binding IsPinned}" Value="True">
            <Setter TargetName="PinBar" Property="Visibility" Value="Visible" />
            <Setter TargetName="PinIcon" Property="Text" Value="📌" />
            <Setter TargetName="PinIcon" Property="Foreground" Value="#FF1A1A1A" />
        </DataTrigger>
        <DataTrigger Binding="{Binding IsPinned}" Value="False">
            <Setter TargetName="PinIcon" Property="Text" Value="📌" />
        </DataTrigger>
    </UserControl.Triggers>
</UserControl>
